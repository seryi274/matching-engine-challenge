# Terraform state -- contains secrets and resource details
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directory
.terraform/

# Provider lock file -- regenerated by terraform init
.terraform.lock.hcl

# Variable files that may contain secrets
terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Plan files
*.tfplan
